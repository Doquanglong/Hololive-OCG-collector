{
  // Serves the exported web build (dist/) as a static site on Cloudflare,
  // with SPA fallback so deep links / refreshes return index.html.
  "name": "hololive-ocg-collector",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
